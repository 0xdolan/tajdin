{
  "name": "tajdin",
  "private": true,
  "version": "0.0.1",
  "description": "Tajdîn - always by your side; Radio Browser.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:watch": "vite build --watch",
    "verify:dist": "node scripts/verify-extension.mjs",
    "verify:extension": "npm run build && npm run verify:dist",
    "pack:zip": "node scripts/pack-extension.mjs",
    "pack:extension": "npm run build && npm run pack:zip",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"scripts/**/*.mjs\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "generate:icon-128": "node scripts/generate-extension-icon-128.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource/vazirmatn": "^5.2.8",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "fuse.js": "^7.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-virtuoso": "^4.18.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.0.279",
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
