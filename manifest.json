{
  "manifest_version": 3,
  "name": "Tajdîn",
  "version": "0.0.1",
  "description": "Tajdîn - always by your side; Radio Browser.",
  "minimum_chrome_version": "116",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self'; frame-ancestors 'none';"
  },
  "permissions": ["alarms", "clipboardWrite", "offscreen", "storage"],
  "host_permissions": [
    "https://all.api.radio-browser.info/*",
    "https://de1.api.radio-browser.info/*",
    "https://*.radio-browser.info/*",
    "http://*/*",
    "https://*/*"
  ],
  "icons": {
    "16": "logo/tajdin-logo-black.png",
    "32": "logo/tajdin-logo-black.png",
    "48": "logo/tajdin-logo-black.png",
    "128": "logo/tajdin-logo-black.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Tajdîn",
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "logo/tajdin-logo-black.png",
      "32": "logo/tajdin-logo-black.png",
      "48": "logo/tajdin-logo-black.png",
      "128": "logo/tajdin-logo-black.png"
    }
  },
  "options_ui": {
    "page": "src/settings/index.html",
    "open_in_tab": true
  },
  "commands": {
    "tajdin-toggle-playback": {
      "description": "Play or pause the current station",
      "suggested_key": {
        "default": "MediaPlayPause",
        "mac": "MediaPlayPause"
      }
    },
    "tajdin-next-station": {
      "description": "Next station (playlist or favourites)",
      "suggested_key": {
        "default": "MediaNextTrack",
        "mac": "MediaNextTrack"
      }
    },
    "tajdin-previous-station": {
      "description": "Previous station (playlist or favourites)",
      "suggested_key": {
        "default": "MediaPreviousTrack",
        "mac": "MediaPreviousTrack"
      }
    },
    "tajdin-toggle-mute": {
      "description": "Mute or unmute",
      "suggested_key": {
        "default": "Ctrl+Shift+9",
        "mac": "Command+Shift+9"
      }
    },
    "tajdin-open-popup": {
      "description": "Open the Tajdîn popup",
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      }
    }
  }
}
