{
  "manifest_version": 3,
  "name": "Zeng",
  "version": "0.0.1",
  "description": "Worldwide radio in your browser (Radio Browser).",
  "minimum_chrome_version": "116",
  "permissions": ["alarms", "offscreen", "storage"],
  "host_permissions": [
    "https://all.api.radio-browser.info/*",
    "https://de1.api.radio-browser.info/*",
    "https://*.radio-browser.info/*"
  ],
  "icons": {
    "16": "icons/zeng-radio-50.png",
    "32": "icons/zeng-radio-50.png",
    "48": "icons/zeng-radio-50.png",
    "128": "icons/zeng-radio-100.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Zeng",
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/zeng-radio-50.png",
      "32": "icons/zeng-radio-50.png",
      "48": "icons/zeng-radio-50.png",
      "128": "icons/zeng-radio-100.png"
    }
  },
  "options_ui": {
    "page": "src/settings/index.html",
    "open_in_tab": true
  }
}
